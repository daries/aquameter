# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Data directory (Docker: gunakan /data, lokal: biarkan kosong) ─────────────
# DATA_DIR=/data

# ── Database (opsional — default SQLite di DATA_DIR) ──────────────────────────
# DB_PATH=/data/aquameter.db

# ── MySQL/MariaDB (jika menggunakan profil mysql) ─────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=aquameter
MYSQL_USER=aquameter
MYSQL_PASSWORD=aquameter123

# ── PostgreSQL (jika menggunakan profil postgres) ─────────────────────────────
POSTGRES_DB=aquameter
POSTGRES_USER=aquameter
POSTGRES_PASSWORD=aquameter123

# ── Frontend (Vite — hanya untuk development) ─────────────────────────────────
VITE_API_BASE=/api
VITE_APP_NAME=AquaMeter
VITE_APP_VERSION=2.0.0
